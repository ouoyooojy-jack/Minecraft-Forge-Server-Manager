                  "children": [
                    {
                      "type": "text",
                      "id": "home-title",
                      "fill": "$color.fg",
                      "content": "Forge Server Manager",
                      "fontFamily": "Inter",
                      "fontSize": "$font.size.title",
                      "fontWeight": "700"
