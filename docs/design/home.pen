{
  "version": "2.14",
  "children": [
    {
      "type": "frame",
      "id": "window",
      "x": 0,
      "y": 0,
      "theme": {
        "mode": "dark"
      },
      "width": 2560,
      "height": 1440,
      "fill": "$color.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "frame",
          "id": "title-bar",
          "width": "fill_container",
          "fill": "$color.bg",
          "padding": [
            0,
            16
          ],
          "justifyContent": "space_between",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "title-bar-app-name",
              "fill": "$color.fg",
              "content": "Mc Server Manager",
              "fontFamily": "Inter",
              "fontSize": "$font.size.small",
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "title-bar-controls",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "icon",
                  "id": "tb-sun",
                  "width": 16,
                  "height": 16,
                  "icon": "sun",
                  "library": "lucide",
                  "fill": "$color.muted"
                },
                {
                  "type": "icon",
                  "id": "tb-min",
                  "width": 16,
                  "height": 16,
                  "icon": "minus",
                  "library": "lucide",
                  "fill": "$color.muted"
                },
                {
                  "type": "icon",
                  "id": "tb-max",
                  "width": 16,
                  "height": 16,
                  "icon": "square",
                  "library": "lucide",
                  "fill": "$color.muted"
                },
                {
                  "type": "icon",
                  "id": "tb-x",
                  "width": 16,
                  "height": 16,
                  "icon": "x",
                  "library": "lucide",
                  "fill": "$color.muted"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "body",
          "width": "fill_container",
          "height": "fill_container",
          "fill": "$color.bg",
          "children": [
            {
              "type": "frame",
              "id": "sidebar",
              "height": "fill_container",
              "fill": "$color.rail_bg",
              "stroke": "$color.border",
              "strokeWidth": {
                "right": 1
              },
              "layout": "vertical",
              "gap": 12,
              "padding": [
                12,
                0
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "icon",
                  "id": "sb-hamburger",
                  "width": 20,
                  "height": 20,
                  "icon": "menu",
                  "library": "lucide",
                  "fill": "$color.muted"
                },
                {
                  "type": "icon",
                  "id": "sb-home",
                  "width": 20,
                  "height": 20,
                  "icon": "house",
                  "library": "lucide",
                  "fill": "$color.fg"
                },
                {
                  "type": "icon",
                  "id": "sb-download",
                  "width": 20,
                  "height": 20,
                  "icon": "download",
                  "library": "lucide",
                  "fill": "$color.muted"
                },
                {
                  "type": "icon",
                  "id": "sb-settings",
                  "width": 20,
                  "height": 20,
                  "icon": "settings",
                  "library": "lucide",
                  "fill": "$color.muted"
                }
              ]
            },
            {
              "type": "frame",
              "id": "home-content",
              "width": "fill_container",
              "height": "fill_container",
              "fill": "$color.bg",
              "layout": "vertical",
              "gap": "$gap.section",
              "padding": 24,
              "children": [
                {
                  "type": "frame",
